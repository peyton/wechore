APP_WORKSPACE="${APP_WORKSPACE:-app/WeChore.xcworkspace}"
WECHORE_FLAVOR="${WECHORE_FLAVOR:-dev}"
DEV_APP_SCHEME="${DEV_APP_SCHEME:-WeChoreDev}"
DEV_APP_IDENTIFIER="${DEV_APP_IDENTIFIER:-app.peyton.wechore.dev}"
DEV_APP_PRODUCT_NAME="${DEV_APP_PRODUCT_NAME:-WeChoreDev}"
RELEASE_APP_SCHEME="${RELEASE_APP_SCHEME:-WeChore}"
RELEASE_APP_IDENTIFIER="${RELEASE_APP_IDENTIFIER:-app.peyton.wechore}"
RELEASE_APP_PRODUCT_NAME="${RELEASE_APP_PRODUCT_NAME:-WeChore}"
APP_SCHEME="${APP_SCHEME:-}"
APP_IDENTIFIER="${APP_IDENTIFIER:-}"
RUN_APP_PATH="${RUN_APP_PATH:-}"

DEFAULT_IPHONE_DEVICE="${DEFAULT_IPHONE_DEVICE:-iPhone 17 Pro}"
DEFAULT_IPAD_DEVICE="${DEFAULT_IPAD_DEVICE:-iPad Pro 11-inch (M5)}"
RUN_SIMULATOR_NAME="${RUN_SIMULATOR_NAME:-WeChore Run iPhone 17 Pro}"
TEST_IPHONE_SIMULATOR_NAME="${TEST_IPHONE_SIMULATOR_NAME:-WeChore Test iPhone 17 Pro}"
TEST_IPAD_SIMULATOR_NAME="${TEST_IPAD_SIMULATOR_NAME:-WeChore Test iPad Pro}"

TEST_XCODEBUILD_ARGS="${TEST_XCODEBUILD_ARGS:--parallel-testing-enabled NO -maximum-parallel-testing-workers 1}"

BUILD_DERIVED_DATA="${BUILD_DERIVED_DATA:-.DerivedData/build}"
RUN_DERIVED_DATA="${RUN_DERIVED_DATA:-.DerivedData/run}"
TEST_DERIVED_DATA="${TEST_DERIVED_DATA:-.DerivedData/test}"
ARCHIVE_DERIVED_DATA="${ARCHIVE_DERIVED_DATA:-.DerivedData/archive}"

ARCHIVE_PATH="${ARCHIVE_PATH:-.build/WeChore.xcarchive}"
EXPORT_PATH="${EXPORT_PATH:-.build/export}"
TEAM_ID="${TEAM_ID:-3VDQ4656LX}"

CLOUDKIT_CONTAINER_ID="${CLOUDKIT_CONTAINER_ID:-iCloud.app.peyton.wechore}"
CLOUDKIT_TEAM_ID="${CLOUDKIT_TEAM_ID:-3VDQ4656LX}"
CLOUDKIT_ENVIRONMENT="${CLOUDKIT_ENVIRONMENT:-development}"
CLOUDKIT_SCHEMA_FILE="${CLOUDKIT_SCHEMA_FILE:-.state/cloudkit/wechore-cloudkit-schema.json}"
